
use "./src/bfs.in";

qtree ~
    QTreeNode(
        QTreeNode(
            QTreeLeaf(UserValue(None)),
            QTreeLeaf(UserValue(Some(1))),
            QTreeLeaf(UserValue(Some(3))),
            QTreeLeaf(UserValue(None))
        ),
        QTreeNode(
            QTreeLeaf(UserValue(Some(1))),
            QTreeLeaf(UserValue(None)),
            QTreeLeaf(UserValue(Some(2))),
            QTreeLeaf(UserValue(Some(3)))
        ),
        QTreeLeaf(UserValue(None)),
        QTreeNode(
            QTreeLeaf(UserValue(None)),
            QTreeLeaf(UserValue(Some(2))),
            QTreeLeaf(UserValue(Some(3))),
            QTreeLeaf(UserValue(None))
        )
    );

graph ~ SparseMatrix(4, 4, 9, 16, qtree);

vtree ~
  BTreeNode(BTreeNode(BTreeLeaf(UserValue(Some(1))), BTreeLeaf(UserValue(None))),
            BTreeLeaf(UserValue(None))
            );

startVertices ~ SparseVector(4, 1, 4, vtree);
bfs_level(r) ~ (graph, startVertices);
r;
