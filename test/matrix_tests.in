use "./src/matrix.in";

// QTreeNode(QTreeLeaf(3), QTreeLeaf(4), QTreeLeaf(1), QTreeLeaf(2))

op_add_2(r, yval) >< None => r ~ Some(yval);
op_add_2(r, yval) >< Some(xval) =>
  w << Add(xval, yval),
  r ~ Some(w);

op_add_1(r, x) >< None => r ~ x;
op_add_1(r, x) >< Some(yval) => op_add_2(r, yval) ~ x;

op_add(r) >< (x, y) =>
  op_add_1(r, x) ~ y;


// QTreeNode(
//  QTreeNode(QTreeLeaf(2), QTreeLeaf(0), QTreeLeaf(1), QTreeLeaf(0)),
//  QTreeLeaf(3),
//  QTreeNode(QTreeLeaf(1), QTreeLeaf(1), QTreeLeaf(0), QTreeLeaf(1)),
//  QTreeLeaf(0)
// )



Eq(r)~(QTreeLeaf(3), QTreeLeaf(3));
r; free r;


QTreeMkNode(r) ~ (QTreeLeaf(3), QTreeLeaf(3), QTreeLeaf(3), QTreeLeaf(3));
r; free r;

QTreeMkNode(r) ~ (
  QTreeNode(QTreeLeaf(1), QTreeLeaf(2), QTreeLeaf(3), QTreeLeaf(4)),
  QTreeLeaf(5),
  QTreeLeaf(6),
  QTreeLeaf(7));
r; free r;

QTreeMkNode(tree1) ~ (
  QTreeLeaf(UserValue(Some(1))),
  QTreeLeaf(UserValue(Some(2))),
  QTreeLeaf(UserValue(Some(3))),
  QTreeLeaf(UserValue(Some(4)))
);
tree2 ~ QTreeLeaf(UserValue(Some(1)));

QTreeMap2(r) ~ (%op_add, 8, tree1, tree2);
r; free r tree1 tree2;

// NN1D
// NN2D
// 123D
// DDDD

tree1 ~ QTreeNode(
  QTreeLeaf(UserValue(None)),
  QTreeNode(
    QTreeLeaf(UserValue(Some(1))),
    QTreeLeaf(Dummy),
    QTreeLeaf(UserValue(Some(2))),
    QTreeLeaf(Dummy)
  ),
  QTreeNode(
    QTreeLeaf(UserValue(Some(1))),
    QTreeLeaf(UserValue(Some(2))),
    QTreeLeaf(Dummy),
    QTreeLeaf(Dummy)
  ),
  QTreeNode(
    QTreeLeaf(UserValue(Some(3))),
    QTreeLeaf(Dummy),
    QTreeLeaf(Dummy),
    QTreeLeaf(Dummy)
  )
);

tree2 ~ QTreeNode(
  QTreeLeaf(UserValue(None)),
  QTreeNode(
    QTreeLeaf(UserValue(Some(1))),
    QTreeLeaf(Dummy),
    QTreeLeaf(UserValue(Some(2))),
    QTreeLeaf(Dummy)
  ),
  QTreeNode(
    QTreeLeaf(UserValue(Some(1))),
    QTreeLeaf(UserValue(Some(2))),
    QTreeLeaf(Dummy),
    QTreeLeaf(Dummy)
  ),
  QTreeNode(
    QTreeLeaf(UserValue(Some(3))),
    QTreeLeaf(Dummy),
    QTreeLeaf(Dummy),
    QTreeLeaf(Dummy)
  )
);

QTreeMap2(r) ~ (%op_add, 4, tree1, tree2);
r; free r tree1 tree2;

coo ~ [(0, 0, 1)];
QTreeFromCoordinateList(r) ~ (3, 3, 4, coo);
r; free r coo;
